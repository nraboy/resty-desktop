{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resty Desktop",
  "version": "0.3.7",
  "identifier": "com.nraboy.restydesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Resty Desktop",
        "width": 1366,
        "height": 768,
        "minWidth": 1280,
        "minHeight": 720,
        "backgroundColor": "#030712"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "dmg", "nsis", "msi"],
    "publisher": "Nic Raboy",
    "copyright": "Copyright © 2026 Nic Raboy",
    "license": "MIT",
    "category": "Utility",
    "shortDescription": "A desktop GUI client for the Restic backup tool",
    "longDescription": "Resty Desktop is a cross-platform desktop application that wraps the Restic CLI backup tool, providing a graphical interface for managing repositories, snapshots, and scheduled backups.",
    "macOS": {
      "infoPlist": "./Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
